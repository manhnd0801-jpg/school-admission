# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/tuyen_sinh_db"

# =============================================================================
# REDIS
# =============================================================================
# Redis connection URL (used by BullMQ and rate limiting)
REDIS_URL="redis://localhost:6379"

# =============================================================================
# NEXTAUTH.JS
# =============================================================================
# Secret key for JWT signing — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
# The canonical URL of your deployment
NEXTAUTH_URL="http://localhost:3000"

# =============================================================================
# AWS S3 / CLOUDFLARE R2 (Object Storage)
# =============================================================================
S3_BUCKET_NAME="tuyen-sinh-uploads"
S3_REGION="ap-southeast-1"
S3_ACCESS_KEY_ID="your-access-key-id"
S3_SECRET_ACCESS_KEY="your-secret-access-key"
# For Cloudflare R2, set the endpoint URL:
# S3_ENDPOINT_URL="https://<account-id>.r2.cloudflarestorage.com"
S3_ENDPOINT_URL=""
# Public CDN base URL for uploaded files
S3_PUBLIC_URL="https://your-cdn-domain.com"

# =============================================================================
# EMAIL (SMTP / Resend)
# =============================================================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="Tuyển Sinh THPT <tuyen-sinh@school.edu.vn>"

# Email address(es) to receive lead notifications (comma-separated)
NOTIFICATION_EMAIL="tuyen-sinh@school.edu.vn"

# Optional: Resend API key (alternative to SMTP)
# RESEND_API_KEY="re_xxxxxxxxxxxx"

# =============================================================================
# GOOGLE ANALYTICS
# =============================================================================
# GA4 Measurement ID (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# =============================================================================
# APPLICATION
# =============================================================================
# Set to "true" to enable maintenance mode (redirects all traffic to /maintenance)
MAINTENANCE_MODE="false"

# Node environment
NODE_ENV="development"

# Application URL (used for generating absolute URLs in emails, sitemaps, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# School name (used in metadata, emails, etc.)
NEXT_PUBLIC_SCHOOL_NAME="Trường THPT"

# =============================================================================
# WORKER PROCESS
# =============================================================================
# BullMQ concurrency settings
WORKER_CONCURRENCY="5"
